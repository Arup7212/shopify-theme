<div class="video-grid-container">
  <div class="video-grid">
    {% for block in section.blocks %}
      <div class="video-grid-item">
        {% if block.settings.video_url %}
          {%- assign video_id = '' -%}
          {%- if block.settings.video_url contains 'youtu.be/' -%}
            {%- assign video_id = block.settings.video_url | split: 'youtu.be/' | last -%}
          {%- elsif block.settings.video_url contains 'youtube.com/watch?v=' -%}
            {%- assign video_id = block.settings.video_url | split: 'v=' | last -%}
            {%- assign video_id = video_id | split: '&' | first -%}
          {%- endif -%}

          <iframe
            width="200%"
            height="500"
            src="https://www.youtube.com/embed/{{ video_id }}"
            frameborder="0"
            allowfullscreen
          ></iframe>
        {% endif %}
        {% if block.settings.video_title %}
          <h3>{{ block.settings.video_title }}</h3>
        {% endif %}
      </div>
    {% endfor %}
  </div>
</div>

{% schema %}
{
  "name": "YouTube Video Gallery",
  "settings": [],
  "blocks": [
    {
      "type": "video",
      "name": "Video",
      "settings": [
        {
          "type": "text",
          "id": "video_url",
          "label": "YouTube Video URL"
        },
        {
          "type": "text",
          "id": "video_title",
          "label": "Video Title"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "YouTube Gallery",
      "category": "Media"
    }
  ]
}
{% endschema %}

<style>
  .video-grid-container {
    padding: 20px;
  }

  .video-grid {
    display: grid;
    grid-template-columns: repeat(1, 1fr);
    gap: 15px;
  }

  .video-grid-item {
    position: relative;
    overflow: hidden;
    border-radius: 8px;
    box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
  }

  .video-grid-item iframe {
    width: 100%;
    height: auto;
  }

  .video-grid-item h3 {
    text-align: center;
    font-size: 18px;
    margin-top: 10px;
  }

  /* Make it 3 columns on larger screens */
  @media (min-width: 1024px) {
    .video-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  /* Make it 2 columns on medium-sized screens */
  @media (min-width: 768px) and (max-width: 1023px) {
    .video-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  /* Make it 1 column on mobile screens */
  @media (max-width: 767px) {
    .video-grid {
      grid-template-columns: repeat(1, 1fr);
    }
  }
</style>
