<price-range class="facets__price">
    <div class="range-slider">
    <input
      class="range-min"
      name="{{ filter.min_value.param_name }}"
      id="{{ id_prefix }}{{ filter.label | escape }}-GTE"
      {%- if filter.min_value.value -%}
        value="{{ filter.min_value.value | money_without_currency | ceil }}"
        {% else %}
         value="{{ filter.min_value.value | default: 0 | ceil }}"
      {%- endif -%}
      type="range"
      inputmode="decimal"
      placeholder="0"
      data-pattern="\d| |,|\."
      data-min="0"
      data-max="{{ filter.range_max | money_without_currency | ceil }}"
       min="0" 
        max="{{ filter.range_max | money_without_currency | replace: ',', '' | ceil }}" 
    >
  
    <input
      class="range-max"
      name="{{ filter.max_value.param_name }}"
      id="{{ id_prefix }}{{ filter.label | escape }}-LTE"
      {%- if filter.max_value.value -%}
        value="{{ filter.max_value.value | money_without_currency | ceil }}"
        {% else %}
         value="{{ filter.range_max | money_without_currency | replace: ',', '' | ceil }}"
      {%- endif -%}
      type="range"
      inputmode="decimal"
      placeholder="{{ filter.range_max | money_without_currency | ceil }}"
      data-pattern="\d| |,|\."
      data-min="0"
      data-max="{{ filter.range_max | money_without_currency | ceil }}"
       min="0" 
        max="{{ filter.range_max | money_without_currency | replace: ',', '' | ceil }}" 
    >
  
         <!-- Range Track -->
      <div class="range-track"></div>
  
      <!-- Display for Min and Max Prices -->
      <div class="price-display 12">
        <span class="bubble min-price">{{ filter.min_value.value | money_without_currency | default: 0 | ceil }}</span> 
        - 
        <span class="bubble max-price">{{ filter.range_max | money_without_currency | replace: ',', '' | ceil }}</span>
      </div>
  
      </div>
  </price-range>
  
 
<style>
  /* General Container */
.facets__price {
  position: relative;
  width: 100%;
}

.range-slider {
  position: relative;
  width: 100%;
  height: 50px;
}

.range-slider input[type="range"] {
  position: absolute;
  width: 100%;
  height: 4px;
  -webkit-appearance: none;
  appearance: none;
  background: #b71c1c;
  pointer-events: none;
}

.range-slider input[type="range"]::-webkit-slider-thumb {
  -webkit-appearance: none;
  width: 20px;
  height: 20px;
  background: #555;
  border-radius: 50%;
  cursor: pointer;
  pointer-events: auto;
  position: relative;
  z-index: 2; /* Default thumb z-index */
  transition: transform 0.2s ease-in-out;
}

.range-slider input[type="range"]:hover::-webkit-slider-thumb,
.range-slider input[type="range"]:active::-webkit-slider-thumb {
  transform: scale(1.2); /* Slightly increase size when active */
  z-index: 3; /* Bring thumb above the track */
}

.range-slider input[type="range"]::-moz-range-thumb {
  width: 20px;
  height: 20px;
  background: #555;
  border-radius: 50%;
  cursor: pointer;
  pointer-events: auto;
  position: relative;
  z-index: 2; /* Default thumb z-index */
}

.range-slider input[type="range"]:hover::-moz-range-thumb,
.range-slider input[type="range"]:active::-moz-range-thumb {
  transform: scale(1.2); /* Slightly increase size when active */
  z-index: 3; /* Bring thumb above the track */
}

.range-slider input[type="range"]::-ms-thumb {
  width: 20px;
  height: 20px;
  background: #555;
  border-radius: 50%;
  cursor: pointer;
  pointer-events: auto;
  position: relative;
  z-index: 2; /* Default thumb z-index */
}

.range-slider input[type="range"]:hover::-ms-thumb,
.range-slider input[type="range"]:active::-ms-thumb {
  transform: scale(1.2); /* Slightly increase size when active */
  z-index: 3; /* Bring thumb above the track */
}

.range-slider .range-track {
  position: absolute;
  top: 50%;
  height: 4px;
  background-color: #007aff;
  border-radius: 4px;
  width: 100%;
  transform: translateY(-50%);
  z-index: 1; /* Ensure track stays below the thumb */
}

.price-display {
  margin-top: 30px;
  display: flex;
  justify-content: space-between;
}

.bubble {
  font-size: 16px;
  color: #333;
  background: #fff;
  border: 1px solid #aaa;
  border-radius: 4px;
  padding: 0 0.75em;
  height: 2.5em;
  line-height: 2.5em;
  text-align: center;
  display: inline-block;
}


.background-image-hourly {
    position: relative;
    background-position: 8px;
    width: 100%;
    height: 570px;
    display: flex;
}

.rules-section ul {
    list-style: none;
    padding-left: 35px;
    padding-top: 120px;
    max-width: 615px;
}

#ProductCountDesktop{
  display: none;
}
.filtter_off{
  display: none;
}
@media(max-width: 768px){
  .for_flex_box{
    display: flex !important;
    justify-content: space-between;
  }
  .filtter_off{
  display: initial;
  }
  .mobile-facets__summary .mobile-facets__sort{
    display: none;
  }
  .details_wrapper.filter\.p\.m\.custom\.search_product.hidefilteroption{
    display: none;
  }
 
}
</style>